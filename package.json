{
  "name": "web-learning-e1",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.x",
    "npm": ">=10.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"app/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx,css}\"",
    "check:docker-config": "node ./scripts/check-docker-config.mjs",
    "validate": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run check:docker-config"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "@mui/stylis-plugin-rtl": "^7.3.7",
    "next": "16.2.1",
    "openai": "^6.16.0",
    "react": "19.2.2",
    "react-dom": "19.2.2",
    "react-markdown": "^10.1.0",
    "react-media-recorder": "^1.7.2",
    "remark-gfm": "^4.0.1",
    "stylis": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/stylis": "^4.2.7",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "cross-spawn": "^7.0.6",
    "glob": "^10.5.0",
    "minimatch": "^9.0.8",
    "picomatch": "^4.0.4",
    "tar": "^7.5.11",
    "undici": "^7.24.6"
  }
}
